---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedArticles from '../components/FeaturedArticles';
import ArticleCardGrid from '../components/ArticleCardGrid';
import SearchBar from '../components/SearchBar';
import { loadAllArticles, ALL_CATEGORIES } from '../lib/articles';

const allArticles = loadAllArticles();
---

<BaseLayout
  title="寬覺堂 - 佛學經典、高僧大德開示錄修行指引"
  description="寬覺堂 - 收錄佛教經典、高僧大德開示錄、修行指引等珍貴法寶"
  canonical="https://kjt-website.vercel.app/"
>
  <Hero />

  <main class="container mx-auto px-4 py-10 md:py-12">
    <div class="mb-14">
      <SearchBar articles={allArticles} client:idle />
    </div>

    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-bold text-gray-800 font-chinese md:text-3xl">隨機精選</h2>
    </div>

    <FeaturedArticles allArticles={allArticles} client:load />

    <section id="articles" class="mt-16 md:mt-20">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-4xl font-bold text-gray-800 font-chinese md:text-3xl">分類文章列表</h2>
          <p class="mt-3 max-w-2xl text-xl leading-relaxed text-gray-600 md:text-base">
            以卡片方式瀏覽目前典藏，切換分類或輸入關鍵字後，可快速找到想讀的文章。
          </p>
        </div>
        <div class="rounded-3xl bg-amber-100/80 px-5 py-4 text-xl text-amber-800 shadow-sm md:rounded-2xl md:px-4 md:py-3 md:text-sm">
          共找到 {allArticles.length} 篇
        </div>
      </div>

      <div class="mt-8 flex gap-4 overflow-x-auto pb-2 touch-manipulation scrollbar-none" role="tablist" aria-label="文章分類篩選">
        <a
          href="/page/1/"
          class="min-w-[132px] rounded-full px-6 py-3 text-lg font-medium transition-all duration-300 md:min-w-0 md:px-6 md:py-2 md:text-base bg-gradient-to-r from-amber-500 to-orange-500 text-white shadow-lg shadow-amber-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
        >
          全部
        </a>
        {ALL_CATEGORIES.slice(1).map((cat) => (
          <a
            href={`/category/${encodeURIComponent(cat)}/`}
            class="min-w-[132px] rounded-full px-6 py-3 text-lg font-medium transition-all duration-300 md:min-w-0 md:px-6 md:py-2 md:text-base border border-gray-200 bg-white/90 text-gray-700 hover:bg-white hover:shadow-xl md:bg-white/80 md:backdrop-blur-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
          >
            {cat}
          </a>
        ))}
      </div>

      <ArticleCardGrid articles={allArticles.slice(0, 20)} />

      <div class="mt-6 flex flex-col gap-4 rounded-3xl bg-white/80 px-5 py-5 shadow-sm md:rounded-2xl md:px-4 md:py-4 md:flex-row md:items-center md:justify-between">
        <p class="text-lg text-gray-600 md:text-sm">每頁顯示 20 篇文章。</p>
        <div class="flex flex-wrap items-center gap-3 md:gap-2">
          <a
            href="/page/2/"
            class="rounded-full border border-amber-200 px-5 py-3 text-lg font-medium text-gray-700 transition hover:bg-amber-50 md:px-4 md:py-2 md:text-sm"
          >
            下一頁
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
