---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SearchBar from '../../../components/SearchBar';
import ArticleCardGrid from '../../../components/ArticleCardGrid';
import { loadAllArticles, ALL_CATEGORIES } from '../../../lib/articles';

export async function getStaticPaths() {
  const allArticles = loadAllArticles();
  const categories = ALL_CATEGORIES.slice(1);
  const pageSize = 20;
  const paths: { params: { category: string; page: string }; props: Record<string, unknown> }[] = [];

  for (const cat of categories) {
    const filtered = allArticles.filter((a) => a.category === cat);
    const totalPages = Math.ceil(filtered.length / pageSize);
    for (let i = 0; i < totalPages; i++) {
      const page = i + 1;
      paths.push({
        params: { category: cat, page: String(page) },
        props: { category: cat, page, totalPages, articles: filtered.slice(i * pageSize, (i + 1) * pageSize) },
      });
    }
  }
  return paths;
}

const { category, page, totalPages, articles } = Astro.props;
const allArticles = loadAllArticles();
const filteredLength = allArticles.filter((a) => a.category === category).length;
---

<BaseLayout
  title={`${category} 分類文章 第${page}頁 - 寬覺堂`}
  description={`${category}分類佛學文章列表第${page}頁 - 寬覺堂收錄佛教經典、高僧大德開示錄、修行指引等珍貴法寶`}
  canonical={`https://kjt-website.vercel.app/category/${encodeURIComponent(category)}/${page}/`}
>
  <main class="container mx-auto px-4 py-24">
    <div class="mb-10">
      <SearchBar articles={allArticles} client:idle />
    </div>

    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-4xl font-bold text-gray-800 font-chinese md:text-3xl">{category} 分類文章</h1>
        <p class="mt-3 max-w-2xl text-xl leading-relaxed text-gray-600 md:text-base">
          瀏覽「{category}」分類的佛學文章。
        </p>
      </div>
      <div class="rounded-3xl bg-amber-100/80 px-5 py-4 text-xl text-amber-800 shadow-sm md:rounded-2xl md:px-4 md:py-3 md:text-sm">
        共 {filteredLength} 篇，第 {page} / {totalPages} 頁
      </div>
    </div>

    <div class="mt-8 flex gap-4 overflow-x-auto pb-2 touch-action-manipulation scrollbar-none" role="tablist" aria-label="文章分類篩選">
      <a
        href="/page/1/"
        class="min-w-[132px] rounded-full px-6 py-3 text-lg font-medium transition-all duration-300 md:min-w-0 md:px-6 md:py-2 md:text-base border border-gray-200 bg-white/90 text-gray-700 hover:bg-white hover:shadow-xl md:bg-white/80 md:backdrop-blur-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
      >
        全部
      </a>
      {ALL_CATEGORIES.slice(1).map((cat) => (
        <a
          href={`/category/${encodeURIComponent(cat)}/`}
          class={`min-w-[132px] rounded-full px-6 py-3 text-lg font-medium transition-all duration-300 md:min-w-0 md:px-6 md:py-2 md:text-base ${
            cat === category
              ? 'bg-gradient-to-r from-amber-500 to-orange-500 text-white shadow-lg shadow-amber-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2'
              : 'border border-gray-200 bg-white/90 text-gray-700 hover:bg-white hover:shadow-xl md:bg-white/80 md:backdrop-blur-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2'
          }`}
        >
          {cat}
        </a>
      ))}
    </div>

    <ArticleCardGrid articles={articles} />

    <div class="mt-6 flex flex-col gap-4 rounded-3xl bg-white/80 px-5 py-5 shadow-sm md:rounded-2xl md:px-4 md:py-4 md:flex-row md:items-center md:justify-between">
      <p class="text-lg text-gray-600 md:text-sm">每頁顯示 20 篇文章。</p>
      <div class="flex flex-wrap items-center gap-3 md:gap-2">
        {page > 1 && (
          <a
            href={`/category/${encodeURIComponent(category)}/${page - 1}/`}
            class="rounded-full border border-amber-200 px-5 py-3 text-lg font-medium text-gray-700 transition hover:bg-amber-50 md:px-4 md:py-2 md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
          >
            上一頁
          </a>
        )}
        <span class="px-2 text-lg text-gray-600 md:text-sm">{page} / {totalPages}</span>
        {page < totalPages && (
          <a
            href={`/category/${encodeURIComponent(category)}/${page + 1}/`}
            class="rounded-full border border-amber-200 px-5 py-3 text-lg font-medium text-gray-700 transition hover:bg-amber-50 md:px-4 md:py-2 md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
          >
            下一頁
          </a>
        )}
      </div>
    </div>
  </main>
</BaseLayout>
