---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="找不到頁面 - 寬覺堂">
  <main class="container mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-gray-800 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">找不到此頁面</p>
    <a href="/" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-amber-500 to-orange-500 px-8 py-4 text-lg font-medium text-white transition-all duration-300 shadow-lg hover:from-amber-600 hover:to-orange-600">
      回到首頁
    </a>
  </main>
</BaseLayout>
